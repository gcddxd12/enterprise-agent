# 企业智能客服Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========== 核心 API 密钥 ==========

# 阿里云百炼 DashScope API Key (必填)
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== 监控系统配置 ==========

# LangSmith 配置 (可选: https://smith.langchain.com)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=enterprise-agent-monitoring
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=console
ENVIRONMENT=development

# 报警配置 (可选)
ALERT_WEBHOOK_URL=your_webhook_url_here
ALERT_EMAIL=your_email@example.com
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# 系统标识
INSTANCE_ID=enterprise-agent-01
