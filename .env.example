# 企业智能客服Agent环境变量配置模板
# 复制此文件为.env并填入实际值

# ========== 核心API密钥 ==========

# 阿里云百炼API密钥 (必需)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== 监控系统配置 ==========

# LangSmith配置 (可选: https://smith.langchain.com)
# 用于工作流跟踪、调试和性能分析
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=enterprise-agent-monitoring
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=console  # json, console, plain
ENVIRONMENT=development  # development, staging, production

# 报警配置 (可选)
# Webhook报警 (例如Slack、钉钉、企业微信)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 邮件报警
ALERT_EMAIL=your_email@example.com

# Slack Webhook (直接)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ========== 系统标识 ==========

# 实例标识 (用于多实例部署)
INSTANCE_ID=enterprise-agent-01

# ========== 高级配置 ==========

# 向量数据库路径 (可选，默认: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# RAG检索配置
RAG_MAX_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CACHE_ENABLED=true

# 异步执行配置
ASYNC_MAX_WORKERS=4
ASYNC_TIMEOUT_SECONDS=30

# 多模态配置 (如果启用)
MULTIMODAL_ENABLED=true
IMAGE_ANALYSIS_MODEL=clip-vit-base-patch32
OCR_LANGUAGE=chi_sim+eng  # 中文+英文

# ========== 部署配置 ==========

# Web服务器配置
HOST=0.0.0.0
PORT=8501  # Streamlit默认端口
DEBUG=false

# 数据库配置 (如果使用外部数据库)
DATABASE_URL=sqlite:///./data/agent.db
REDIS_URL=redis://localhost:6379/0

# ========== 安全配置 ==========

# API密钥加密密钥 (用于加密存储的API密钥)
ENCRYPTION_KEY=your_encryption_key_here

# 访问令牌 (用于API认证)
API_ACCESS_TOKEN=your_api_access_token_here

# 速率限制
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒